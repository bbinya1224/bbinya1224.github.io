---
import PostCard from './PostCard.astro';
import Pagination from './Pagination.astro';

interface PostData {
  title: string;
  date: Date;
  slug: string;
  category?: string;
  description?: string;
}

interface Props {
  posts: PostData[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
---

<section>
  <h2 class="mb-6 text-sm font-semibold uppercase tracking-widest text-subtle">Posts</h2>

  {posts.length > 0 ? (
    <div>
      {posts.map((post) => (
        <PostCard
          title={post.title}
          description={post.description}
          date={post.date}
          slug={post.slug}
          category={post.category}
        />
      ))}
    </div>
  ) : (
    <p class="py-12 text-center text-subtle">포스트가 없습니다.</p>
  )}

  <Pagination currentPage={currentPage} totalPages={totalPages} />
</section>
