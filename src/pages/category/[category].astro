---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getSortedPosts, toPostData } from '@/lib/posts';
import { resolveSiteOrigin } from '@/lib/site';
import { toRouteSegment } from '@/lib/taxonomy';

export async function getStaticPaths() {
  const allPosts = await getSortedPosts();

  const categories = new Map<string, typeof allPosts>();
  allPosts.forEach((post) => {
    if (post.data.category) {
      const cat = post.data.category;
      if (!categories.has(cat)) categories.set(cat, []);
      categories.get(cat)!.push(post);
    }
  });

  return Array.from(categories, ([category, posts]) => ({
    params: { category },
    props: { posts, categoryName: category },
  }));
}

const { posts, categoryName } = Astro.props;

const siteOrigin = resolveSiteOrigin(Astro.site);
---

<BaseLayout title={categoryName} canonicalUrl={`${siteOrigin}/category/${toRouteSegment(categoryName)}`}>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-ink">{categoryName}</h1>
    <p class="mt-2 text-subtle">{posts.length}개의 포스트</p>
  </div>

  <div>
    {posts.map((post) => {
      const data = toPostData(post);
      return (
        <PostCard
          title={data.title}
          description={data.description}
          date={data.date}
          slug={data.slug}
          category={data.category}
        />
      );
    })}
  </div>
</BaseLayout>
