---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeContent from '@/components/HomeContent.astro';
import { getSortedPosts, toPostData, POSTS_PER_PAGE } from '@/lib/posts';
import { resolveSiteOrigin } from '@/lib/site';

export async function getStaticPaths() {
  const allPosts = await getSortedPosts();
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
  if (totalPages <= 1) return [];

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2;
    const start = (page - 1) * POSTS_PER_PAGE;
    return {
      params: { page: String(page) },
      props: {
        posts: allPosts.slice(start, start + POSTS_PER_PAGE).map(toPostData),
        page,
        totalPages,
      },
    };
  });
}

const { posts, page, totalPages } = Astro.props;

const siteOrigin = resolveSiteOrigin(Astro.site);
const prevUrl = page === 2 ? '/' : `/page/${page - 1}`;
const nextUrl = page < totalPages ? `/page/${page + 1}` : null;
---

<BaseLayout title={`Page ${page}`} canonicalUrl={`${siteOrigin}/page/${page}`}>
  <Fragment slot="head">
    <link rel="prev" href={`${siteOrigin}${prevUrl}`} />
    {nextUrl && <link rel="next" href={`${siteOrigin}${nextUrl}`} />}
  </Fragment>
  <HomeContent posts={posts} currentPage={page} totalPages={totalPages} />
</BaseLayout>
