# Giscus Configuration
# Get these values from https://giscus.app/
PUBLIC_GISCUS_REPO=your-username/your-repo
PUBLIC_GISCUS_REPO_ID=your-repo-id
PUBLIC_GISCUS_CATEGORY=your-category
PUBLIC_GISCUS_CATEGORY_ID=your-category-id

# Google Analytics
PUBLIC_GA_ID=G-XXXXXXXXXX
GA_PROPERTY_ID=your-property-id
GA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GA_PRIVATE_KEY="your-private-key-here"

# Google Site Verification
PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token
